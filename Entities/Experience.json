{
  "name": "Experience",
  "type": "object",
  "properties": {
    "company": {
      "type": "string",
      "description": "Company name"
    },
    "role": {
      "type": "string",
      "description": "Job title/role"
    },
    "period": {
      "type": "string",
      "description": "Time period (e.g., Summer 2024)"
    },
    "description": {
      "type": "string",
      "description": "Description of work"
    },
    "order": {
      "type": "number",
      "description": "Display order"
    }
  },
  "required": [
    "company",
    "role"
  ]
}